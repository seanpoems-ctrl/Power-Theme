# Copy to ".env" and fill in. Do not commit real values.
# Python scripts load this via python-dotenv. Restart `npm start` after changing REACT_APP_*.

# Google Gemini (Python: GEMINI_API_KEY or GOOGLE_API_KEY)
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Alpaca Markets
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# React (Create React App — only REACT_APP_* are exposed to the browser)
REACT_APP_GEMINI_KEY=
REACT_APP_FINNHUB_KEY=

# Interactive Brokers — ibkr_client.py
IBKR_HOST=127.0.0.1
IBKR_PORT=4002

# ibkr_ws_server.py
TWS_HOST=127.0.0.1
TWS_PORT=7497
TWS_CLIENT_ID=20
WS_PORT=5003
THEMATIC_JSON=public/thematic_data.json

# market_briefing_engine.py (optional)
DATABASE_URL=
